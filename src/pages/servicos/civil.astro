---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Contact from "../../components/Contact.astro";
import { ShieldCheck, Scale, Building2, Users, ChevronRight, CheckCircle2, ArrowRight, Handshake, FileText } from "lucide-astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Como blindar o meu patrimônio contra processos judiciais?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A blindagem patrimonial (ou planejamento sucessório e societário) envolve a criação de holdings, doações com reserva de usufruto e estruturação contratual para proteger seus bens pessoais contra dívidas trabalhistas, fiscais ou disputas familiares."
      }
    },
    {
      "@type": "Question",
      "name": "O que fazer em caso de quebra de contrato comercial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Em caso de descumprimento contratual, é fundamental notificar a parte infratora extrajudicialmente. Caso não haja acordo, ingressamos com uma ação de execução ou rescisão contratual com perdas e danos para garantir a reparação financeira do seu negócio."
      }
    }
  ]
};
---

<Layout
  title="Direito Civil | Rodrigues Fontenelle Advocacia"
  description="Blindagem patrimonial, contratos, indenizações e direito de família. Proteja seus negócios e sua família com segurança jurídica absoluta."
>
  <Header />

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-dark pt-20">
    <!-- Refined Luxury Dark Background -->
    <div class="absolute inset-0 z-0 overflow-hidden bg-dark">
      <!-- Animated Subtle Golden Corner Glows -->
      <div class="absolute top-[-20%] right-[-10%] w-[70%] h-[70%] rounded-full bg-[radial-gradient(circle,rgba(212,175,55,0.07)_0%,transparent_70%)] blur-[80px]" style="animation: glow-pulse 8s ease-in-out infinite;"></div>
      <div class="absolute bottom-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-[radial-gradient(circle,rgba(212,175,55,0.05)_0%,transparent_70%)] blur-[80px]" style="animation: glow-pulse 10s ease-in-out infinite reverse;"></div>
      
      <!-- Elegant Animated Diagonal Lines (Metallic Gold) -->
      <div class="absolute inset-0 opacity-[0.85]">
        <div class="absolute -top-[50%] left-[20%] w-[2px] h-[200%] origin-center shadow-[0_0_15px_rgba(252,246,186,0.6)]" style="background: linear-gradient(to bottom, transparent 0%, rgba(179,135,40,0.6) 35%, #FCF6BA 50%, rgba(212,175,55,0.8) 65%, transparent 100%); transform: rotate(35deg); animation: beam-slide-down 12s linear infinite;"></div>
        <div class="absolute -top-[50%] right-[20%] w-[2px] h-[200%] origin-center shadow-[0_0_15px_rgba(252,246,186,0.6)]" style="background: linear-gradient(to bottom, transparent 0%, rgba(179,135,40,0.6) 35%, #FCF6BA 50%, rgba(212,175,55,0.8) 65%, transparent 100%); transform: rotate(-35deg); animation: beam-slide-up 15s linear infinite;"></div>
      </div>
      
      <!-- Premium Matte Noise Texture -->
      <div class="absolute inset-0 opacity-[0.04] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
      
      <!-- Base Gradient to ensure text readability -->
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent"></div>
    </div>

    <!-- Gold Orbs -->
    <div class="absolute top-[30%] -left-[10%] w-[500px] h-[500px] bg-gold-primary/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-[10%] -right-[10%] w-[600px] h-[600px] bg-gold-accent/10 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
      <div class="hero-badge-anim inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gold-primary/30 bg-gold-primary/10 backdrop-blur-md mb-8">
        <Building2 class="w-4 h-4 text-gold-primary" />
        <span class="text-xs font-bold tracking-[0.2em] text-gold-light uppercase">Especialistas em Direito Civil</span>
      </div>

      <h1 class="hero-title-anim font-display text-[clamp(2.5rem,6vw,5.5rem)] leading-[1.05] tracking-tight mb-8 text-white">
        Proteja seu patrimônio <br/>
        <span class="text-gradient-gold">
          antes que seja tarde.
        </span>
      </h1>

      <p class="hero-desc-anim text-lg md:text-xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-12">
        Ações preventivas e contenciosas de alta complexidade. Defendemos sua empresa, sua família e seus bens com estratégias jurídicas sólidas e blindadas contra imprevistos.
      </p>

      <div class="hero-cta-anim flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contato" class="group relative inline-flex items-center justify-center gap-2 sm:gap-3 px-6 sm:px-10 py-3 sm:py-4 bg-gradient-to-r from-[#D4AF37] via-[#F3E5AB] to-[#D4AF37] text-dark font-semibold tracking-widest uppercase text-[10px] sm:text-[11px] rounded-full overflow-hidden transition-all shadow-[0_4px_20px_rgba(212,175,55,0.2)] hover:shadow-[0_4px_30px_rgba(212,175,55,0.4)] hover:scale-[1.02]">
          <div class="absolute inset-0 bg-gradient-to-r from-[#F3E5AB] via-[#D4AF37] to-[#F3E5AB] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="relative z-10">Falar com um especialista</span>
          <ArrowRight class="w-3.5 h-3.5 sm:w-4 sm:h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </section>

  <!-- Sub-serviços (Glassmorphism) -->
  <section class="py-24 bg-[#0c0a09] relative overflow-hidden">
    <!-- Animated Glowing Orbs -->
    <div class="absolute top-1/4 -left-[20%] w-[600px] h-[600px] bg-gold-primary/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 -right-[20%] w-[600px] h-[600px] bg-gold-accent/10 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-3 gap-8">
        
        <div class="service-feature-card relative p-8 rounded-2xl bg-gradient-to-b from-[#1a1510] to-[#0a0804] border border-gold-primary/20 backdrop-blur-md hover:border-gold-primary/60 transition-all duration-500 hover:shadow-[0_8px_40px_rgba(212,175,55,0.15)] hover:-translate-y-2 group overflow-hidden">
          <div class="absolute inset-0 noise-bg opacity-20 pointer-events-none"></div>
          <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-gold-primary/50 to-transparent"></div>
          
          <div class="relative z-10 w-12 h-12 rounded-full bg-gold-primary/10 flex items-center justify-center mb-6 text-gold-light border border-gold-primary/20 group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(212,175,55,0.2)] group-hover:shadow-[0_0_25px_rgba(252,246,186,0.4)]">
            <Building2 class="w-6 h-6" />
          </div>
          <h3 class="relative z-10 font-display text-2xl text-gold-light mb-4 group-hover:text-white transition-colors">Contratos Empresariais</h3>
          <p class="relative z-10 text-white/70 text-sm leading-relaxed mb-6">
            Elaboramos e revisamos contratos complexos para mitigar riscos, proteger sua propriedade intelectual e garantir o cumprimento de acordos comerciais sem brechas legais.
          </p>
          <ul class="relative z-10 space-y-2 mb-6">
            {["Contratos de Sociedade", "Termos de Confidencialidade (NDA)", "Rescisões Contratuais", "Execução de Dívidas"].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/80 group-hover:text-white transition-colors">
                <CheckCircle2 class="w-4 h-4 text-gold-primary flex-shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="service-feature-card relative p-8 rounded-2xl bg-gradient-to-b from-[#1a1510] to-[#0a0804] border border-gold-primary/20 backdrop-blur-md hover:border-gold-primary/60 transition-all duration-500 hover:shadow-[0_8px_40px_rgba(212,175,55,0.15)] hover:-translate-y-2 group overflow-hidden">
          <div class="absolute inset-0 noise-bg opacity-20 pointer-events-none"></div>
          <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-gold-primary/50 to-transparent"></div>
          
          <div class="relative z-10 w-12 h-12 rounded-full bg-gold-primary/10 flex items-center justify-center mb-6 text-gold-light border border-gold-primary/20 group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(212,175,55,0.2)] group-hover:shadow-[0_0_25px_rgba(252,246,186,0.4)]">
            <ShieldCheck class="w-6 h-6" />
          </div>
          <h3 class="relative z-10 font-display text-2xl text-gold-light mb-4 group-hover:text-white transition-colors">Responsabilidade Civil</h3>
          <p class="relative z-10 text-white/70 text-sm leading-relaxed mb-6">
            Representação enérgica em ações de indenização. Defendemos você e sua empresa em casos de dano material, moral ou estético decorrentes de negligência ou quebra contratual.
          </p>
          <ul class="relative z-10 space-y-2 mb-6">
            {["Erro Médico", "Danos Morais e Materiais", "Defesa do Consumidor", "Acidentes e Sinistros"].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/80 group-hover:text-white transition-colors">
                <CheckCircle2 class="w-4 h-4 text-gold-primary flex-shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="service-feature-card relative p-8 rounded-2xl bg-gradient-to-b from-[#1a1510] to-[#0a0804] border border-gold-primary/20 backdrop-blur-md hover:border-gold-primary/60 transition-all duration-500 hover:shadow-[0_8px_40px_rgba(212,175,55,0.15)] hover:-translate-y-2 group overflow-hidden">
          <div class="absolute inset-0 noise-bg opacity-20 pointer-events-none"></div>
          <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-gold-primary/50 to-transparent"></div>
          
          <div class="relative z-10 w-12 h-12 rounded-full bg-gold-primary/10 flex items-center justify-center mb-6 text-gold-light border border-gold-primary/20 group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(212,175,55,0.2)] group-hover:shadow-[0_0_25px_rgba(252,246,186,0.4)]">
            <Users class="w-6 h-6" />
          </div>
          <h3 class="relative z-10 font-display text-2xl text-gold-light mb-4 group-hover:text-white transition-colors">Direito de Família</h3>
          <p class="relative z-10 text-white/70 text-sm leading-relaxed mb-6">
            Atuação humanizada mas implacável na defesa dos seus interesses em processos de sucessão, partilha de bens de alto valor e organização do seu legado para o futuro.
          </p>
          <ul class="relative z-10 space-y-2 mb-6">
            {["Inventários Complexos", "Planejamento Sucessório", "Divórcio e Partilha de Bens", "Pacto Antenupcial"].map(item => (
              <li class="flex items-center gap-2 text-sm text-white/80 group-hover:text-white transition-colors">
                <CheckCircle2 class="w-4 h-4 text-gold-primary flex-shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Por que nós? -->
  <section class="py-24 bg-[#f8f6f3] text-dark relative overflow-hidden">
    <!-- Texture Overlay -->
    <div class="absolute inset-0 header-marble opacity-60 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="why-us-reveal">
          <h2 class="font-display text-4xl md:text-5xl mb-6">
            O seu legado não aceita <span class="text-[#8B6914] block">amadorismo jurídico.</span>
          </h2>
          <p class="text-lg text-dark/70 leading-relaxed mb-8">
            Enquanto muitos advogados atuam apenas "apagando incêndios", nossa mentalidade é preventiva e estratégica. 
            Nós estruturamos a sua vida pessoal e empresarial de forma que, caso um litígio aconteça, você já esteja posicionado em vantagem.
          </p>
          
          <div class="space-y-6">
            <!-- Item 01 -->
            <div class="group relative p-6 bg-white rounded-2xl border border-gold-primary/20 hover:border-gold-primary/60 transition-all duration-500 hover:shadow-[0_8px_30px_rgba(212,175,55,0.15)] overflow-hidden">
               <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b from-gold-light via-gold-primary to-gold-dark"></div>
               <div class="flex gap-4">
                 <div class="w-12 h-12 rounded-full bg-gold-primary/10 flex-shrink-0 flex items-center justify-center border border-gold-primary/30 group-hover:bg-gold-primary/20 transition-colors">
                   <span class="font-display font-bold text-gold-dark text-lg">01</span>
                 </div>
                 <div>
                   <h4 class="font-display text-xl mb-2 text-dark group-hover:text-gold-dark transition-colors">Visão 360 Graus</h4>
                   <p class="text-dark/70 text-sm leading-relaxed">Não analisamos um contrato de forma isolada; entendemos o impacto tributário, sucessório e trabalhista de cada decisão que você toma.</p>
                 </div>
               </div>
            </div>
            
            <!-- Item 02 -->
            <div class="group relative p-6 bg-white rounded-2xl border border-gold-primary/20 hover:border-gold-primary/60 transition-all duration-500 hover:shadow-[0_8px_30px_rgba(212,175,55,0.15)] overflow-hidden">
               <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b from-gold-light via-gold-primary to-gold-dark"></div>
               <div class="flex gap-4">
                 <div class="w-12 h-12 rounded-full bg-gold-primary/10 flex-shrink-0 flex items-center justify-center border border-gold-primary/30 group-hover:bg-gold-primary/20 transition-colors">
                   <span class="font-display font-bold text-gold-dark text-lg">02</span>
                 </div>
                 <div>
                   <h4 class="font-display text-xl mb-2 text-dark group-hover:text-gold-dark transition-colors">Resolução Extrajudicial</h4>
                   <p class="text-dark/70 text-sm leading-relaxed">Priorizamos a negociação e acordos altamente favoráveis para evitar o desgaste e o custo de processos judiciais que duram anos.</p>
                 </div>
               </div>
            </div>
          </div>
        </div>
        
        <div class="relative why-us-image w-full aspect-square md:aspect-auto md:h-full min-h-[450px]">
          <!-- Luxury Abstract Glassmorphism Dashboard Element -->
          <div class="absolute inset-0 bg-[#0a0a0a] rounded-3xl shadow-2xl overflow-hidden flex flex-col justify-between p-8 border border-gold/10 group transform transition-transform duration-700 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(212,175,55,0.15)]">
            <!-- Background elements -->
            <div class="absolute top-[-20%] right-[-20%] w-[70%] h-[70%] bg-[radial-gradient(circle,rgba(212,175,55,0.12)_0%,transparent_70%)] blur-[40px] rounded-full group-hover:scale-110 transition-transform duration-700"></div>
            
            <!-- Decorative diagonal line -->
            <div class="absolute top-[-50%] right-[30%] w-[1px] h-[200%] bg-gradient-to-b from-transparent via-gold/30 to-transparent transform rotate-[35deg] shadow-[0_0_10px_rgba(212,175,55,0.2)]"></div>

            <!-- Header -->
            <div class="relative z-10 flex justify-between items-start">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gold-dark to-gold-primary p-[1px]">
                  <div class="w-full h-full bg-[#0a0a0a] rounded-xl flex items-center justify-center">
                    <Scale class="w-6 h-6 text-gold-light" />
                  </div>
                </div>
                <div>
                  <h5 class="text-white font-display text-base lg:text-lg leading-tight uppercase tracking-wide">Advocacia Cível Estratégica</h5>
                  <p class="text-gold/60 text-[9px] uppercase tracking-widest font-bold mt-1">Soluções Preventivas e Resolutivas</p>
                </div>
              </div>
              <div class="px-2 py-1 rounded-full bg-blue-900/40 border border-blue-500/20 text-blue-300 text-[9px] uppercase font-bold tracking-widest shadow-[0_0_10px_rgba(59,130,246,0.1)]">
                VALOR PATRIMONIAL GERADO
              </div>
            </div>

            <!-- Center Graphic area (Dashboard) -->
            <div class="relative z-10 mt-16 mb-12 flex-1 flex flex-col justify-center items-center w-full">
              <!-- Central connecting lines SVG -->
              <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-30" viewBox="0 0 400 300">
                <line x1="200" y1="150" x2="200" y2="40" stroke="#D4AF37" stroke-width="1" stroke-dasharray="4 4" />
                <line x1="200" y1="150" x2="40" y2="150" stroke="#D4AF37" stroke-width="1" stroke-dasharray="4 4" />
                <line x1="200" y1="150" x2="360" y2="150" stroke="#D4AF37" stroke-width="1" stroke-dasharray="4 4" />
                <line x1="200" y1="150" x2="200" y2="260" stroke="#D4AF37" stroke-width="1" stroke-dasharray="4 4" />
              </svg>
              
              <div class="relative w-full h-full max-w-[340px] max-h-[340px] flex flex-col items-center justify-center">
                
                <!-- TOP: Risco de Litígio -->
                <div class="absolute top-[-50px] flex flex-col items-center">
                  <span class="text-[8px] md:text-[9px] text-white/60 uppercase tracking-widest mb-1 text-center font-bold">Risco de Litígio</span>
                  <div class="flex items-end gap-1.5 h-10 mt-1">
                    <div class="flex flex-col justify-between h-full text-[6px] text-white/40 mr-1 pb-0.5">
                      <span>100%</span>
                      <span>70%</span>
                      <span>50%</span>
                      <span>10%</span>
                    </div>
                    <div class="w-3 bg-gold/80 h-[100%] rounded-t-sm shadow-[0_0_8px_rgba(212,175,55,0.4)]"></div>
                    <div class="w-3 bg-blue-900/60 h-[70%] rounded-t-sm"></div>
                    <div class="w-3 bg-blue-900/60 h-[50%] rounded-t-sm"></div>
                    <div class="w-3 bg-blue-900/60 h-[30%] rounded-t-sm"></div>
                    <div class="w-3 bg-blue-900/60 h-[10%] rounded-t-sm"></div>
                    <div class="w-3 bg-blue-400 h-[10%] rounded-t-sm shadow-[0_0_8px_rgba(96,165,250,0.6)] relative">
                      <span class="absolute -top-4 left-1/2 -translate-x-1/2 text-[8px] text-blue-300 font-bold">10%</span>
                    </div>
                  </div>
                  <span class="text-[7px] text-white/40 uppercase tracking-widest mt-2">Reduzido para: 10%</span>
                </div>

                <!-- LEFT: Taxa de Sucesso -->
                <div class="absolute left-[-20px] sm:left-[-10px] top-1/2 -translate-y-1/2 flex flex-col items-center">
                  <span class="text-[8px] md:text-[9px] text-white/60 uppercase tracking-widest mb-2 text-center w-24 leading-tight font-bold">Taxa de Sucesso Extrajudicial</span>
                  <div class="relative w-16 h-16 rounded-full flex items-center justify-center bg-[#0a0a0a]">
                    <!-- SVG Circle Progress -->
                    <svg class="absolute inset-0 w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                      <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="8" />
                      <circle cx="50" cy="50" r="45" fill="none" stroke="#D4AF37" stroke-width="8" stroke-dasharray="282.7" stroke-dashoffset="33.9" class="drop-shadow-[0_0_5px_rgba(212,175,55,0.5)]" />
                    </svg>
                    <span class="text-white font-display font-bold text-lg">88%</span>
                  </div>
                  <span class="text-[7px] text-white/40 uppercase tracking-widest mt-2">Sucesso: 88%</span>
                </div>

                <!-- CENTER: Handshake -->
                <div class="relative w-24 h-24 rounded-full border border-gold/30 flex items-center justify-center bg-[#0a0a0a] z-10 shadow-[0_0_30px_rgba(212,175,55,0.2)]">
                  <div class="absolute inset-[-15px] rounded-full border border-gold/20 border-dashed animate-[spin_20s_linear_infinite]"></div>
                  <div class="absolute inset-[-30px] rounded-full border border-gold/5 border-dashed animate-[spin_30s_linear_infinite_reverse]"></div>
                  <Handshake class="w-10 h-10 text-gold-light drop-shadow-[0_0_10px_rgba(252,246,186,0.6)]" />
                </div>

                <!-- RIGHT: Valor Recuperado -->
                <div class="absolute right-[-20px] sm:right-[-10px] top-1/2 -translate-y-1/2 flex flex-col items-center">
                  <span class="text-[8px] md:text-[9px] text-white/60 uppercase tracking-widest mb-2 text-center w-28 leading-tight font-bold">Valor Recuperado / Protegido</span>
                  <div class="flex flex-col items-center mb-1">
                    <span class="text-gold-light font-display font-bold text-2xl leading-none">R$ 7.2</span>
                    <span class="text-gold-light font-display font-bold text-[11px] tracking-widest mt-1">MILHÕES+</span>
                  </div>
                  <!-- Mini sparkline chart -->
                  <svg class="w-24 h-8 overflow-visible mt-1" viewBox="0 0 100 30">
                    <path d="M0,25 Q10,25 20,20 T40,22 T60,15 T80,18 T100,5" fill="none" stroke="#D4AF37" stroke-width="2" class="drop-shadow-[0_0_4px_rgba(212,175,55,0.6)]" />
                    <circle cx="100" cy="5" r="2" fill="#fff" class="drop-shadow-[0_0_4px_rgba(255,255,255,0.8)]" />
                    <!-- Area under curve -->
                    <path d="M0,25 Q10,25 20,20 T40,22 T60,15 T80,18 T100,5 L100,30 L0,30 Z" fill="url(#goldGradientCivil)" opacity="0.3" />
                    <defs>
                      <linearGradient id="goldGradientCivil" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#D4AF37" />
                        <stop offset="100%" stop-color="transparent" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>

                <!-- BOTTOM: Contratos -->
                <div class="absolute bottom-[-50px] flex flex-col items-center">
                  <span class="text-[8px] md:text-[9px] text-white/60 uppercase tracking-widest mb-1 text-center font-bold">Contratos Otimizados</span>
                  <div class="flex items-center gap-2 bg-blue-900/20 px-4 py-2 rounded-lg border border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.1)]">
                    <FileText class="w-4 h-4 text-blue-300" />
                    <span class="text-blue-300 font-display font-bold text-base">4.100+</span>
                  </div>
                </div>

              </div>
            </div>
            
            <!-- Bottom Info -->
