              <div>
                <p class="text-white/40 text-[9px] uppercase tracking-[0.2em] mb-1">Relações Jurídicas Estáveis</p>
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
                  <p class="text-gold-light text-lg font-display font-bold uppercase tracking-wide">Acompanhamento Contínuo</p>
                </div>
