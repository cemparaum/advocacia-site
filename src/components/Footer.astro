---
import { Instagram, Linkedin, Facebook } from "lucide-astro";
---

<footer
  class="bg-[#f8f6f3] border-t border-[#B38728]/10 pt-16 pb-8 relative overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.03] mix-blend-multiply pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-[#D4AF37]/[0.05] rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div class="mx-auto w-full max-w-[1400px] px-6 relative z-10">
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16"
    >
      <!-- Brand -->
      <div class="lg:col-span-1">
        <h3
          class="font-display text-2xl text-[#0c0a09] tracking-widest uppercase mb-6"
        >
          Rodrigues<br /><span class="text-[#D4AF37]">Fontenelle</span>
        </h3>
        <p class="text-[#0c0a09]/60 text-sm leading-relaxed mb-8">
          O padrão ouro em Direito Previdenciário. Estratégia, ética e
          resultados expressivos para garantir o seu futuro financeiro.
        </p>
        <div class="flex gap-4 relative z-10">
          <a
            href="#"
            class="w-10 h-10 rounded-full bg-white flex items-center justify-center border border-[#B38728]/20 text-[#0c0a09]/70 hover:text-[#D4AF37] hover:border-[#D4AF37] transition-all shadow-sm"
          >
            <Instagram class="w-4 h-4" />
          </a>
          <a
            href="#"
            class="w-10 h-10 rounded-full bg-white flex items-center justify-center border border-[#B38728]/20 text-[#0c0a09]/70 hover:text-[#D4AF37] hover:border-[#D4AF37] transition-all shadow-sm"
          >
            <Linkedin class="w-4 h-4" />
          </a>
          <a
            href="#"
            class="w-10 h-10 rounded-full bg-white flex items-center justify-center border border-[#B38728]/20 text-[#0c0a09]/70 hover:text-[#D4AF37] hover:border-[#D4AF37] transition-all shadow-sm"
          >
            <Facebook class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="relative z-10">
        <h4 class="text-[#0c0a09] font-display text-lg mb-6">Navegação</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="#inicio"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Início</a
            >
          </li>
          <li>
            <a
              href="#servicos"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Especialidades</a
            >
          </li>
          <li>
            <a
              href="#diferenciais"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Diferenciais</a
            >
          </li>
          <li>
            <a
              href="#sobre"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Sobre Nós</a
            >
          </li>
          <li>
            <a
              href="#faq"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Dúvidas Frequentes</a
            >
          </li>
        </ul>
      </div>

      <!-- Especialidades -->
      <div class="relative z-10">
        <h4 class="text-[#0c0a09] font-display text-lg mb-6">Especialidades</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="#servicos"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Aposentadoria Especial</a
            >
          </li>
          <li>
            <a
              href="#servicos"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Planejamento Previdenciário</a
            >
          </li>
          <li>
            <a
              href="#servicos"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Revisão da Vida Toda</a
            >
          </li>
          <li>
            <a
              href="#servicos"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors"
              >Benefícios por Incapacidade</a
            >
          </li>
        </ul>
      </div>

      <!-- Contato -->
      <div class="relative z-10">
        <h4 class="text-[#0c0a09] font-display text-lg mb-6">Contato</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="mailto:contato@rodriguesfontenelle.com.br"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors block"
              >contato@rodriguesfontenelle.com.br</a
            >
          </li>
          <li>
            <a
              href="https://wa.me/5511999999999"
              target="_blank"
              class="text-[#0c0a09]/60 hover:text-[#D4AF37] text-sm transition-colors block"
              >(11) 99999-9999</a
            >
          </li>
          <li>
            <span class="text-[#0c0a09]/60 text-sm block"
              >Av. Paulista, 1000 - Sala 100<br />São Paulo, SP</span
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="h-px w-full bg-gradient-to-r from-transparent via-[#B38728]/20 to-transparent mb-8 relative z-10"
    >
    </div>

    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left relative z-10"
    >
      <p class="text-[#0c0a09]/40 text-xs">
        &copy; {new Date().getFullYear()} Rodrigues Fontenelle Advocacia. Todos os
        direitos reservados.
      </p>
      <div class="flex gap-6">
        <a
          href="#"
          class="text-[#0c0a09]/40 hover:text-[#0c0a09]/70 text-xs transition-colors"
          >Política de Privacidade</a
        >
        <a
          href="#"
          class="text-[#0c0a09]/40 hover:text-[#0c0a09]/70 text-xs transition-colors"
          >Termos de Uso</a
        >
      </div>
    </div>
  </div>
</footer>
