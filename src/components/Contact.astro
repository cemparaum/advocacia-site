---
import { Phone, Mail, MapPin, ArrowRight } from "lucide-astro";
---

<section
  id="contato"
  class="relative py-24 sm:py-32 overflow-hidden bg-[#0c0a09]"
>
  <div
    class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.03] mix-blend-overlay"
  >
  </div>
  <div
    class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#B38728]/[0.02] rounded-full blur-[150px] pointer-events-none"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-[1400px] px-6">
    <div
      class="bg-[#1a1613] rounded-[2rem] sm:rounded-[3rem] border border-[#B38728]/10 overflow-hidden shadow-2xl relative reveal-slide-up"
    >
      <!-- Glow inside card -->
      <div
        class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-bl from-[#D4AF37]/10 to-transparent blur-[80px] pointer-events-none"
      >
      </div>

      <div class="grid lg:grid-cols-2 gap-0">
        <!-- Left: Contact Info -->
        <div class="p-10 sm:p-16 lg:p-20 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span
                class="text-xs font-bold tracking-[0.25em] uppercase text-[#D4AF37]"
                >Fale Conosco</span
              >
              <div
                class="w-16 h-px bg-gradient-to-r from-[#D4AF37] to-transparent"
              >
              </div>
            </div>
            <h2
              class="font-display leading-[1.05] tracking-tight text-white mb-6"
              style="font-size: clamp(2rem, 3.5vw, 3.5rem);"
            >
              Proteja seu direito.<br />
              <span class="text-gradient-gold">Fale com especialistas.</span>
            </h2>
            <p class="text-white/60 text-lg mb-12 max-w-md leading-relaxed">
              Não deixe o seu futuro financeiro nas mãos do acaso. Agende sua
              consulta inicial sem compromisso e entenda todas as suas opções.
            </p>
          </div>

          <div class="flex flex-col gap-8">
            <a
              href="https://wa.me/5511999999999"
              target="_blank"
              class="flex items-center gap-6 group"
            >
              <div
                class="w-14 h-14 rounded-full bg-[#2a241f] border border-[#B38728]/20 flex items-center justify-center transition-colors group-hover:bg-[#B38728]/10 group-hover:border-[#B38728]/40 shadow-lg"
              >
                <Phone class="w-6 h-6 text-[#D4AF37]" />
              </div>
              <div>
                <span
                  class="block text-white/40 text-xs mb-1 uppercase tracking-widest font-bold"
                  >WhatsApp Direto</span
                >
                <span
                  class="block text-white text-xl font-display transition-colors group-hover:text-[#D4AF37]"
                  >(11) 99999-9999</span
                >
              </div>
            </a>

            <a
              href="mailto:contato@rodriguesfontenelle.com.br"
              class="flex items-center gap-6 group"
            >
              <div
                class="w-14 h-14 rounded-full bg-[#2a241f] border border-[#B38728]/20 flex items-center justify-center transition-colors group-hover:bg-[#B38728]/10 group-hover:border-[#B38728]/40 shadow-lg"
              >
                <Mail class="w-6 h-6 text-[#D4AF37]" />
              </div>
              <div>
                <span
                  class="block text-white/40 text-xs mb-1 uppercase tracking-widest font-bold"
                  >E-mail</span
                >
                <span
                  class="block text-white text-lg font-display transition-colors group-hover:text-[#D4AF37]"
                  >contato@rodriguesfontenelle.com.br</span
                >
              </div>
            </a>

            <div class="flex items-center gap-6 group cursor-default">
              <div
                class="w-14 h-14 rounded-full bg-[#2a241f] border border-[#B38728]/20 flex items-center justify-center shadow-lg"
              >
                <MapPin class="w-6 h-6 text-[#D4AF37]" />
              </div>
              <div>
                <span
                  class="block text-white/40 text-xs mb-1 uppercase tracking-widest font-bold"
                  >Escritório</span
                >
                <span
                  class="block text-white text-lg font-display leading-tight"
                  >Av. Paulista, 1000, Sala 100<br /><span
                    class="text-white/60 text-base">São Paulo - SP</span
                  ></span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Action Area -->
        <div
          class="bg-black/20 p-10 sm:p-16 lg:p-20 border-l border-white/5 flex flex-col justify-center items-center text-center backdrop-blur-sm"
        >
          <div
            class="w-24 h-24 bg-gradient-to-br from-[#D4AF37] to-[#8B6914] rounded-full flex items-center justify-center mb-8 shadow-[0_0_50px_rgba(212,175,55,0.3)]"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              class="w-10 h-10 text-[#1a1613]"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"
              ></path>
            </svg>
          </div>
          <h3 class="font-display text-2xl sm:text-3xl text-white mb-4">
            Iniciar Atendimento
          </h3>
          <p class="text-white/60 mb-10 max-w-sm leading-relaxed">
            Nossa equipe de especialistas responderá em até 15 minutos durante o
            horário comercial.
          </p>

          <a
            href="https://wa.me/5511999999999"
            target="_blank"
            class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 bg-gradient-to-r from-[#B38728] via-[#D4AF37] to-[#B38728] text-[#1a1613] font-bold tracking-[0.15em] uppercase text-xs rounded-full overflow-hidden transition-all shadow-[0_8px_30px_rgba(212,175,55,0.3)] hover:scale-[1.02]"
          >
            <div
              class="absolute inset-0 bg-gradient-to-r from-[#D4AF37] via-[#FCF6BA] to-[#D4AF37] opacity-0 group-hover:opacity-100 transition-opacity duration-600"
            >
            </div>
            <span class="relative z-10">Falar no WhatsApp</span>
            <ArrowRight
              class="w-5 h-5 relative z-10 transition-transform duration-300 group-hover:translate-x-1"
            />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
