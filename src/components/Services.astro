---
import {
  ShieldCheck,
  Scale,
  Briefcase,
  Clock,
  Landmark,
  Baby,
  HeartPulse,
  AlertTriangle,
  ArrowRight,
  ChevronRight,
} from "lucide-astro";
---

<section
  id="servicos"
  class="relative overflow-hidden"
  style="background-color: #f8f6f3;"
>
  <!-- Marble texture background -->
  <div class="absolute inset-0 header-marble opacity-60 pointer-events-none">
  </div>

  <!-- Atmospheric gold glow (subtle on light) -->
  <div
    class="absolute top-[20%] -left-[200px] w-[600px] h-[600px] bg-gold/[0.06] rounded-full blur-[180px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-[10%] -right-[200px] w-[500px] h-[500px] bg-gold-accent/[0.04] rounded-full blur-[150px] pointer-events-none"
  >
  </div>

  <!-- Top gold divider -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/25 to-transparent"
  >
  </div>

  <!-- ===== PART 1: Section Intro ===== -->
  <div
    class="relative z-10 mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-8 lg:px-12 pt-24 sm:pt-32 lg:pt-40"
  >
    <div class="svc-reveal mb-20 sm:mb-24 lg:mb-28">
      <div>
        <div class="flex flex-col items-start gap-2 mb-6">
          <span
            class="text-xs font-bold tracking-[0.25em] uppercase text-[#8B6914]"
            >Áreas de Atuação</span
          >
          <div class="w-24 h-px bg-gradient-to-r from-[#8B6914] to-transparent">
          </div>
        </div>
        <h2
          class="font-display leading-[1.05] tracking-tight text-[#1a1613]"
          style="font-size: clamp(2rem, 5vw, 3.75rem);"
        >
          <span class="block">Expertise que</span>
          <span class="block text-gradient-gold-on-light"
            >transforma direitos</span
          >
          <span class="block">em conquistas.</span>
        </h2>
      </div>
    </div>
  </div>

  <!-- ===== PART 2: Standard Grid ===== -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-8 pb-6">
    <div class="grid lg:grid-cols-3 gap-4 sm:gap-5">
      <!-- Card 1 -->
      <div
        class="svc-card group relative rounded-[1.5rem] sm:rounded-[2rem] overflow-hidden border border-[#B38728]/25 shadow-[0_4px_25px_rgba(179,135,40,0.06)] bg-white/70 backdrop-blur-sm flex flex-col justify-end transition-all duration-700 hover:border-[#B38728] hover:shadow-[0_15px_50px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <!-- Decorative Metallic Number -->
        <div class="absolute top-4 right-5 pointer-events-none select-none">
          <span
            class="font-display font-semibold text-[3.5rem] sm:text-[4.5rem] leading-none bg-gradient-to-br from-[#D4AF37] via-[#FFDF73] to-[#8B6914] opacity-60 bg-clip-text text-transparent tracking-tight drop-shadow-sm"
            style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;"
            >01</span
          >
        </div>

        <!-- Gold glow on hover -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-[#D4AF37]/15 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
        >
        </div>

        <!-- Content -->
        <div class="relative p-5 sm:p-7 pt-16 sm:pt-20">
          <!-- Icon Badge -->
          <div
            class="w-10 h-10 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-4 sm:mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <ShieldCheck class="w-[18px] h-[18px] text-[#8B6914]" />
          </div>

          <!-- Category Label -->
          <span
            class="inline-block text-[9px] font-bold tracking-[0.25em] uppercase text-[#8B6914]/80 mb-2"
            >Direito Previdenciário</span
          >

          <!-- Title -->
          <h3
            class="font-display text-xl sm:text-2xl text-[#1a1613] mb-3 tracking-tight leading-tight"
          >
            Previdenciária
          </h3>

          <!-- Description -->
          <p class="text-sm text-[#1a1613]/40 group-hover:text-[#1a1613]/70 transition-colors duration-500 leading-relaxed mb-5 max-w-md">
            O INSS negou seu benefício? Nós transformamos anos de trabalho na
            aposentadoria segura que você merece.
          </p>

          <!-- Tags Row -->
          <div class="flex flex-wrap gap-2 mb-5">
            {
              ["Aposentadorias", "Revisões", "BPC/LOAS"].map((tag) => (
                <span class="px-2.5 py-1 rounded-full bg-[#B38728]/10 border border-[#B38728]/20 text-[10px] font-semibold text-[#7A5C1A] tracking-wide">
                  {tag}
                </span>
              ))
            }
          </div>

          <!-- CTA -->
          <a
            href={`${import.meta.env.BASE_URL}/servicos/previdenciario`}
            class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.15em] text-[#8B6914] group-hover:text-[#6B5010] transition-colors duration-500"
          >
            <span>Saiba mais</span>
            <ChevronRight
              class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>
        </div>
      </div>

      <!-- Card: Civil -->
      <div
        class="svc-card group relative rounded-[1.5rem] sm:rounded-[2rem] overflow-hidden border border-[#B38728]/25 shadow-[0_4px_25px_rgba(179,135,40,0.06)] bg-white/70 backdrop-blur-sm flex flex-col justify-end transition-all duration-700 hover:border-[#B38728] hover:shadow-[0_15px_50px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <!-- Metallic Number -->
        <div class="absolute top-4 right-5 pointer-events-none select-none">
          <span
            class="font-display font-semibold text-[3.5rem] sm:text-[4.5rem] leading-none bg-gradient-to-br from-[#D4AF37] via-[#FFDF73] to-[#8B6914] opacity-60 bg-clip-text text-transparent tracking-tight drop-shadow-sm"
            style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;"
            >02</span
          >
        </div>

        <div
          class="absolute inset-0 bg-gradient-to-t from-[#D4AF37]/15 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
        >
        </div>

        <div class="relative p-5 sm:p-7 pt-16 sm:pt-20">
          <div
            class="w-10 h-10 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-4 sm:mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <Scale class="w-[18px] h-[18px] text-[#8B6914]" />
          </div>

          <span
            class="inline-block text-[9px] font-bold tracking-[0.25em] uppercase text-[#8B6914]/80 mb-2"
            >Direito Civil</span
          >
          <h3
            class="font-display text-xl sm:text-2xl text-[#1a1613] mb-3 tracking-tight leading-tight"
          >
            Civil
          </h3>
          <p class="text-sm text-[#1a1613]/40 group-hover:text-[#1a1613]/70 transition-colors duration-500 leading-relaxed mb-5 max-w-md">
            Proteja seu patrimônio e seus negócios. Resolvemos conflitos
            contratuais e familiares com estratégias blindadas e segurança
            jurídica absoluta.
          </p>

          <div class="flex flex-wrap gap-2 mb-5">
            {
              ["Contratos", "Indenizações", "Consumidor"].map((tag) => (
                <span class="px-2.5 py-1 rounded-full bg-[#B38728]/10 border border-[#B38728]/20 text-[10px] font-semibold text-[#7A5C1A] tracking-wide">
                  {tag}
                </span>
              ))
            }
          </div>

          <a
            href={`${import.meta.env.BASE_URL}/servicos/civil`}
            class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.15em] text-[#8B6914] group-hover:text-[#6B5010] transition-colors duration-500"
          >
            <span>Saiba mais</span>
            <ChevronRight
              class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>
        </div>
      </div>

      <!-- Card: Trabalhista -->
      <div
        class="svc-card group relative rounded-[1.5rem] sm:rounded-[2rem] overflow-hidden border border-[#B38728]/25 shadow-[0_4px_25px_rgba(179,135,40,0.06)] bg-white/70 backdrop-blur-sm flex flex-col justify-end transition-all duration-700 hover:border-[#B38728] hover:shadow-[0_15px_50px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <!-- Metallic Number -->
        <div class="absolute top-4 right-5 pointer-events-none select-none">
          <span
            class="font-display font-semibold text-[3.5rem] sm:text-[4.5rem] leading-none bg-gradient-to-br from-[#D4AF37] via-[#FFDF73] to-[#8B6914] opacity-60 bg-clip-text text-transparent tracking-tight drop-shadow-sm"
            style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;"
            >03</span
          >
        </div>

        <div
          class="absolute inset-0 bg-gradient-to-t from-[#D4AF37]/15 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
        >
        </div>

        <div class="relative p-5 sm:p-7 pt-16 sm:pt-20">
          <div
            class="w-10 h-10 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-4 sm:mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <Briefcase class="w-[18px] h-[18px] text-[#8B6914]" />
          </div>

          <span
            class="inline-block text-[9px] font-bold tracking-[0.25em] uppercase text-[#8B6914]/80 mb-2"
            >Direito Trabalhista</span
          >
          <h3
            class="font-display text-xl sm:text-2xl text-[#1a1613] mb-3 tracking-tight leading-tight"
          >
            Trabalhista
          </h3>
          <p class="text-sm text-[#1a1613]/40 group-hover:text-[#1a1613]/70 transition-colors duration-500 leading-relaxed mb-5 max-w-md">
            Anos de dedicação não podem ser descartados. Exigimos o pagamento
            integral de verbas rescisórias, horas extras e todos os direitos que
            tentaram sonegar de você.
          </p>

          <div class="flex flex-wrap gap-2 mb-5">
            {
              ["Rescisões", "Horas Extras", "Acidentes"].map((tag) => (
                <span class="px-2.5 py-1 rounded-full bg-[#B38728]/10 border border-[#B38728]/20 text-[10px] font-semibold text-[#7A5C1A] tracking-wide">
                  {tag}
                </span>
              ))
            }
          </div>

          <a
            href={`${import.meta.env.BASE_URL}/servicos/trabalhista`}
            class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.15em] text-[#8B6914] group-hover:text-[#6B5010] transition-colors duration-500"
          >
            <span>Saiba mais</span>
            <ChevronRight
              class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== PART 3: Stats Counter Bar ===== -->
  <div
    class="relative z-10 mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-8 lg:px-12 py-16 sm:py-20 lg:py-24"
  >
    <div
      class="svc-reveal grid grid-cols-2 lg:grid-cols-4 gap-px rounded-2xl sm:rounded-3xl overflow-hidden border border-[#B38728]/20 bg-[#B38728]/10 shadow-[0_8px_30px_rgba(179,135,40,0.08)]"
    >
      <div
        class="bg-white/60 p-6 sm:p-8 lg:p-10 text-center group hover:bg-white/80 backdrop-blur-sm transition-colors duration-500 relative overflow-hidden flex flex-col justify-center"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-[#D4AF37]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
        >
        </div>
        <div
          class="relative z-10 font-display font-semibold text-3xl sm:text-4xl lg:text-5xl text-gradient-gold mb-2 counter-value"
          data-target="500"
        >
          +500
        </div>
        <div
          class="relative z-10 text-[9px] sm:text-[10px] text-[#8B6914] font-bold tracking-[0.2em] uppercase"
        >
          Clientes atendidos
        </div>
      </div>
      <div
        class="bg-white/60 p-6 sm:p-8 lg:p-10 text-center group hover:bg-white/80 backdrop-blur-sm transition-colors duration-500 relative overflow-hidden flex flex-col justify-center"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-[#D4AF37]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
        >
        </div>
        <div
          class="relative z-10 font-display font-semibold text-3xl sm:text-4xl lg:text-5xl text-gradient-gold mb-2"
        >
          98%
        </div>
        <div
          class="relative z-10 text-[9px] sm:text-[10px] text-[#8B6914] font-bold tracking-[0.2em] uppercase"
        >
          Aprovação
        </div>
      </div>
      <div
        class="bg-white/60 p-6 sm:p-8 lg:p-10 text-center group hover:bg-white/80 backdrop-blur-sm transition-colors duration-500 relative overflow-hidden flex flex-col justify-center"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-[#D4AF37]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
        >
        </div>
        <div
          class="relative z-10 font-display font-semibold text-3xl sm:text-4xl lg:text-5xl text-gradient-gold mb-2"
        >
          15+
        </div>
        <div
          class="relative z-10 text-[9px] sm:text-[10px] text-[#8B6914] font-bold tracking-[0.2em] uppercase"
        >
          Anos de experiência
        </div>
      </div>
      <div
        class="bg-white/60 p-6 sm:p-8 lg:p-10 text-center group hover:bg-white/80 backdrop-blur-sm transition-colors duration-500 relative overflow-hidden flex flex-col justify-center"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-[#D4AF37]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
        >
        </div>
        <div
          class="relative z-10 font-display font-semibold text-3xl sm:text-4xl lg:text-5xl text-gradient-gold mb-2"
        >
          3
        </div>
        <div
          class="relative z-10 text-[9px] sm:text-[10px] text-[#8B6914] font-bold tracking-[0.2em] uppercase"
        >
          Áreas de atuação
        </div>
      </div>
    </div>
  </div>

  <!-- ===== PART 4: Specialized Services ===== -->
  <div
    class="relative z-10 mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-8 lg:px-12 pb-24 sm:pb-32 lg:pb-40"
  >
    <div class="svc-reveal flex items-center gap-3 mb-10">
      <div class="w-10 h-px bg-gradient-to-r from-[#8B6914] to-transparent">
      </div>
      <span
        class="text-[10px] font-bold tracking-[0.3em] uppercase text-[#8B6914]"
        >Serviços Especializados</span
      >
    </div>

    <!-- Horizontal scroll on mobile, grid on desktop -->
    <div
      id="services-carousel"
      class="flex lg:grid lg:grid-cols-5 gap-4 lg:gap-5 overflow-x-auto pb-4 lg:pb-0 snap-x snap-mandatory scrollbar-hide -mx-5 px-5 sm:-mx-6 sm:px-6 lg:mx-0 lg:px-0 scroll-smooth"
    >
      <!-- Aposentadorias -->
      <div
        class="svc-card snap-start shrink-0 w-[75vw] sm:w-[45vw] lg:w-auto group relative rounded-2xl overflow-hidden border-x border-b border-[#B38728]/20 border-t-4 border-t-[#B38728] bg-white shadow-[0_8px_30px_rgba(179,135,40,0.08)] transition-all duration-500 hover:border-[#B38728] hover:border-t-[#D4AF37] hover:shadow-[0_15px_40px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <div class="p-6 sm:p-7">
          <div
            class="w-11 h-11 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <Clock class="w-5 h-5 text-[#8B6914]" />
          </div>
          <h4
            class="font-display text-base sm:text-lg text-[#1a1613] font-semibold mb-2 tracking-tight group-hover:text-[#8B6914] transition-colors duration-300"
          >
            Aposentadorias
          </h4>
          <p class="text-[13px] text-[#1a1613]/60 group-hover:text-[#1a1613]/90 transition-colors duration-300 leading-relaxed font-medium">
            Por idade, tempo de contribuição, especial e por invalidez.
          </p>
        </div>
      </div>

      <!-- Revisões -->
      <div
        class="svc-card snap-start shrink-0 w-[75vw] sm:w-[45vw] lg:w-auto group relative rounded-2xl overflow-hidden border-x border-b border-[#B38728]/20 border-t-4 border-t-[#B38728] bg-white shadow-[0_8px_30px_rgba(179,135,40,0.08)] transition-all duration-500 hover:border-[#B38728] hover:border-t-[#D4AF37] hover:shadow-[0_15px_40px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <div class="p-6 sm:p-7">
          <div
            class="w-11 h-11 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <Landmark class="w-5 h-5 text-[#8B6914]" />
          </div>
          <h4
            class="font-display text-base sm:text-lg text-[#1a1613] font-semibold mb-2 tracking-tight group-hover:text-[#8B6914] transition-colors duration-300"
          >
            Revisões
          </h4>
          <p class="text-[13px] text-[#1a1613]/60 group-hover:text-[#1a1613]/90 transition-colors duration-300 leading-relaxed font-medium">
            Revisão da vida toda, teto e buraco negro do INSS.
          </p>
        </div>
      </div>

      <!-- Salário-Maternidade -->
      <div
        class="svc-card snap-start shrink-0 w-[75vw] sm:w-[45vw] lg:w-auto group relative rounded-2xl overflow-hidden border-x border-b border-[#B38728]/20 border-t-4 border-t-[#B38728] bg-white shadow-[0_8px_30px_rgba(179,135,40,0.08)] transition-all duration-500 hover:border-[#B38728] hover:border-t-[#D4AF37] hover:shadow-[0_15px_40px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <div class="p-6 sm:p-7">
          <div
            class="w-11 h-11 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <Baby class="w-5 h-5 text-[#8B6914]" />
          </div>
          <h4
            class="font-display text-base sm:text-lg text-[#1a1613] font-semibold mb-2 tracking-tight group-hover:text-[#8B6914] transition-colors duration-300"
          >
            Salário-Maternidade
          </h4>
          <p class="text-[13px] text-[#1a1613]/60 group-hover:text-[#1a1613]/90 transition-colors duration-300 leading-relaxed font-medium">
            Concessão e recurso para seguradas do INSS.
          </p>
        </div>
      </div>

      <!-- BPC/LOAS -->
      <div
        class="svc-card snap-start shrink-0 w-[75vw] sm:w-[45vw] lg:w-auto group relative rounded-2xl overflow-hidden border-x border-b border-[#B38728]/20 border-t-4 border-t-[#B38728] bg-white shadow-[0_8px_30px_rgba(179,135,40,0.08)] transition-all duration-500 hover:border-[#B38728] hover:border-t-[#D4AF37] hover:shadow-[0_15px_40px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <div class="p-6 sm:p-7">
          <div
            class="w-11 h-11 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <HeartPulse class="w-5 h-5 text-[#8B6914]" />
          </div>
          <h4
            class="font-display text-base sm:text-lg text-[#1a1613] font-semibold mb-2 tracking-tight group-hover:text-[#8B6914] transition-colors duration-300"
          >
            BPC/LOAS
          </h4>
          <p class="text-[13px] text-[#1a1613]/60 group-hover:text-[#1a1613]/90 transition-colors duration-300 leading-relaxed font-medium">
            Benefício para idosos e pessoas com deficiência.
          </p>
        </div>
      </div>

      <!-- Descontos Indevidos -->
      <div
        class="svc-card snap-start shrink-0 w-[75vw] sm:w-[45vw] lg:w-auto group relative rounded-2xl overflow-hidden border-x border-b border-[#B38728]/20 border-t-4 border-t-[#B38728] bg-white shadow-[0_8px_30px_rgba(179,135,40,0.08)] transition-all duration-500 hover:border-[#B38728] hover:border-t-[#D4AF37] hover:shadow-[0_15px_40px_rgba(212,175,55,0.25)] hover:-translate-y-2"
      >
        <div class="p-6 sm:p-7">
          <div
            class="w-11 h-11 rounded-xl bg-[#B38728]/15 border border-[#B38728]/25 flex items-center justify-center mb-5 transition-all duration-500 group-hover:bg-[#B38728]/30 group-hover:border-[#B38728]/50 group-hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] group-hover:scale-110 origin-left"
          >
            <AlertTriangle class="w-5 h-5 text-[#8B6914]" />
          </div>
          <h4
            class="font-display text-base sm:text-lg text-[#1a1613] font-semibold mb-2 tracking-tight group-hover:text-[#8B6914] transition-colors duration-300"
          >
            Descontos Indevidos
          </h4>
