---
import { Menu, X } from "lucide-astro";
---

<header
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
  id="main-header"
>
  <div
    class="absolute inset-0 border-b border-gold/15 shadow-sm overflow-hidden header-marble"
    id="header-bg"
  >
  </div>
  <div
    class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-12 h-20 sm:h-24 flex items-center justify-between transition-all duration-300"
    id="header-container"
  >
    <!-- Logo -->
    <a href={`${import.meta.env.BASE_URL}/`} class="flex items-center gap-3 group min-w-0">
      <img
        src={`${import.meta.env.BASE_URL}/images/logo-rf.jpeg`}
        alt="Rodrigues Fontenelle Advocacia"
        class="h-12 sm:h-14 w-auto rounded-full shadow-md"
      />
      <div class="flex flex-col">
        <span
          class="font-display font-bold text-base sm:text-xl tracking-widest text-dark uppercase leading-[1.1] transition-colors group-hover:text-gold-dark"
          >Rodrigues<br/>Fontenelle</span
        >
        <span
          class="font-body text-[7px] sm:text-[9px] tracking-[0.2em] sm:tracking-[0.35em] text-gold-dark uppercase mt-0.5 sm:mt-1"
          >Advocacia</span
        >
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-4 xl:gap-7">
      <a
        href={`${import.meta.env.BASE_URL}/#servicos`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Áreas de Atuação
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a
        href={`${import.meta.env.BASE_URL}/#diferenciais`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Diferenciais
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a
        href={`${import.meta.env.BASE_URL}/#depoimentos`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Resultados
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a
        href={`${import.meta.env.BASE_URL}/#sobre`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Sobre nós
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a
        href={`${import.meta.env.BASE_URL}/#faq`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Dúvidas
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a
        href={`${import.meta.env.BASE_URL}/#contato`}
        class="text-[11px] xl:text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Contato
        <span class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
      </a>
    </nav>



    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="lg:hidden relative z-[60] text-dark p-2" aria-label="Menu">
      <Menu id="menu-icon" class="w-6 h-6 transition-transform duration-300" />
      <X id="close-icon" class="w-6 h-6 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 rotate-90 transition-all duration-300" />
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-dark/60 backdrop-blur-lg z-[55] flex flex-col justify-center items-center opacity-0 pointer-events-none transition-all duration-300 translate-x-full">
    <nav class="flex flex-col items-center gap-8 relative z-10">
      <a href={`${import.meta.env.BASE_URL}/#servicos`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Áreas de Atuação</a>
      <a href={`${import.meta.env.BASE_URL}/#diferenciais`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Diferenciais</a>
      <a href={`${import.meta.env.BASE_URL}/#depoimentos`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Resultados</a>
      <a href={`${import.meta.env.BASE_URL}/#sobre`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Sobre nós</a>
      <a href={`${import.meta.env.BASE_URL}/#faq`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Dúvidas</a>
      <a href={`${import.meta.env.BASE_URL}/#contato`} class="mobile-link text-xl uppercase tracking-widest font-medium text-gold hover:text-gold-light transition-colors drop-shadow-md">Contato</a>
    </nav>
  </div>
</header>

<script>
  // Shrink header on scroll
  const headerContainer = document.getElementById("header-container");
  const headerBgEl = document.getElementById("header-bg");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      headerContainer?.classList.add("h-16", "sm:h-20");
      headerContainer?.classList.remove("h-20", "sm:h-24");
      headerBgEl?.classList.add("shadow-md");
    } else {
      headerContainer?.classList.add("h-20", "sm:h-24");
      headerContainer?.classList.remove("h-16", "sm:h-20");
      headerBgEl?.classList.remove("shadow-md");
    }
  });

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    console.log("Menu toggled", isMenuOpen);
      if (isMenuOpen) {
        mobileMenuBtn?.classList.remove("text-dark");
        mobileMenuBtn?.classList.add("text-gold");
        mobileMenu?.classList.remove("opacity-0", "pointer-events-none", "translate-x-full");
        mobileMenu?.classList.add("opacity-100", "pointer-events-auto", "translate-x-0");
        menuIcon?.classList.add("opacity-0", "-rotate-90");
        closeIcon?.classList.remove("opacity-0", "rotate-90");
        closeIcon?.classList.add("opacity-100", "rotate-0");
        document.body.style.overflow = "hidden"; // Prevent native scrolling
        if ((window as any).lenis) (window as any).lenis.stop(); // Prevent Lenis scrolling
      } else {
        mobileMenuBtn?.classList.remove("text-gold");
        mobileMenuBtn?.classList.add("text-dark");
        mobileMenu?.classList.add("opacity-0", "pointer-events-none", "translate-x-full");
        mobileMenu?.classList.remove("opacity-100", "pointer-events-auto", "translate-x-0");
        menuIcon?.classList.remove("opacity-0", "-rotate-90");
        closeIcon?.classList.add("opacity-0", "rotate-90");
        closeIcon?.classList.remove("opacity-100", "rotate-0");
        document.body.style.overflow = ""; // Restore native scrolling
        if ((window as any).lenis) (window as any).lenis.start(); // Restore Lenis scrolling
      }
  }

  mobileMenuBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    toggleMenu();
  });

  // Close menu when clicking a link
  mobileLinks.forEach(link => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  // Close menu when clicking outside the nav (on the background overlay)
  mobileMenu?.addEventListener("click", (e) => {
    if (e.target === mobileMenu && isMenuOpen) {
      toggleMenu();
    }
  });
</script>
