---
import { Menu } from "lucide-astro";
---

<header
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
  id="main-header"
>
  <div
    class="absolute inset-0 border-b border-gold/15 shadow-sm overflow-hidden header-marble"
    id="header-bg"
  >
  </div>
  <div
    class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-12 h-20 sm:h-24 flex items-center justify-between transition-all duration-300"
    id="header-container"
  >
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group min-w-0">
      <img
        src={`${import.meta.env.BASE_URL}images/logo-rf.jpeg`}
        alt="Rodrigues Fontenelle Advocacia"
        class="h-12 sm:h-14 w-auto rounded-full shadow-md"
      />
      <div class="flex flex-col">
        <span
          class="font-display font-bold text-base sm:text-xl tracking-widest text-dark uppercase leading-none transition-colors group-hover:text-gold-dark"
          >Rodrigues Fontenelle</span
        >
        <span
          class="font-body text-[7px] sm:text-[9px] tracking-[0.2em] sm:tracking-[0.35em] text-gold-dark uppercase mt-0.5 sm:mt-1"
          >Advocacia</span
        >
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-5 xl:gap-8">
      <a
        href="#sobre"
        class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Sobre nós
        <span
          class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a
        href="#areas"
        class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Áreas de Atuação
        <span
          class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a
        href="#resultados"
        class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Resultados
        <span
          class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a
        href="#contato"
        class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-dark transition-colors relative group"
      >
        Contato
        <span
          class="absolute -bottom-1.5 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
    </nav>

    <!-- Header CTA -->
    <div class="hidden lg:flex">
      <a
        href="#consulta"
        class="group relative inline-flex items-center gap-2 px-7 py-3 rounded-full overflow-hidden bg-gradient-to-r from-[#B38728] via-[#D4AF37] to-[#B38728] shadow-[0_2px_12px_rgba(212,175,55,0.3)] hover:shadow-[0_4px_20px_rgba(212,175,55,0.5)] transition-all duration-300 hover:scale-[1.03]"
      >
        <div
          class="absolute inset-0 bg-gradient-to-r from-[#D4AF37] via-[#FCF6BA] to-[#D4AF37] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        >
        </div>
        <span
          class="relative text-[11px] font-bold text-dark tracking-widest uppercase"
          >Agendar Consulta</span
        >
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="lg:hidden relative z-10 text-dark p-2">
      <Menu class="w-6 h-6" />
    </button>
  </div>
</header>

<script>
  // Shrink header on scroll
  const headerContainer = document.getElementById("header-container");

  window.addEventListener("scroll", () => {
    const headerBgEl = document.getElementById("header-bg");
    if (window.scrollY > 50) {
      headerContainer?.classList.add("h-16", "sm:h-20");
      headerContainer?.classList.remove("h-20", "sm:h-24");
      headerBgEl?.classList.add("shadow-md");
    } else {
      headerContainer?.classList.add("h-20", "sm:h-24");
      headerContainer?.classList.remove("h-16", "sm:h-20");
      headerBgEl?.classList.remove("shadow-md");
    }
  });
</script>
