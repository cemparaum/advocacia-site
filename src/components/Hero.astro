---
import { Scale, ArrowRight, Play } from "lucide-astro";
---

<section class="relative h-screen w-full flex flex-col overflow-hidden bg-dark">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src={`${import.meta.env.BASE_URL}/images/hero-bg.webp`}
      alt="Advogada Especialista"
      class="w-full h-full object-cover object-[65%_15%] sm:object-[70%_15%] opacity-80 mix-blend-luminosity hero-image-scale"
    />
    <!-- Gradient Overlays for readability -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-transparent"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-dark via-dark/50 to-transparent"
    >
    </div>

    <!-- Ambient Gold Glows -->
    <div
      class="absolute top-1/4 left-1/4 w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] lg:w-[600px] lg:h-[600px] bg-gold/15 rounded-full blur-[100px] lg:blur-[140px] mix-blend-screen pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] sm:w-[350px] sm:h-[350px] lg:w-[500px] lg:h-[500px] bg-gold-accent/15 rounded-full blur-[80px] lg:blur-[120px] mix-blend-screen pointer-events-none"
    >
    </div>
  </div>

  <!-- Content Container — flex-1 fills available space, justify-center vertically -->
  <div
    class="relative z-10 mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-8 lg:px-12 flex flex-col items-start justify-center flex-1"
    style="padding-top: clamp(5rem, 12vh, 8rem);"
  >
    <!-- Badge -->
    <div
      class="hero-reveal-item flex flex-col items-start gap-2 mb-6 sm:mb-8"
    >
      <span class="text-[10px] sm:text-xs font-bold tracking-[0.15em] sm:tracking-[0.25em] uppercase text-[#D4AF37]"
        >Previdência • Civil • Trabalhista</span
      >
      <div class="w-12 sm:w-24 h-px bg-gradient-to-r from-[#B38728] to-transparent">
      </div>
    </div>

    <!-- Main Headline -->
    <h1
      class="hero-title font-display font-semibold leading-[1.25] sm:leading-[1.15] max-w-3xl mb-6 sm:mb-8"
      style="font-size: clamp(2rem, 4.5vw, 3.75rem);"
    >
      <span
        class="block text-white mb-2 sm:mb-3"
        >Seu futuro não é uma aposta.</span
      >
      <span class="block text-gradient-gold"
        >É um direito que nós garantimos.</span
      >
    </h1>

    <!-- Subheadline -->
    <p
      class="hero-reveal-item text-gray-300 max-w-xl md:max-w-2xl leading-relaxed sm:leading-relaxed font-light text-[0.95rem] sm:text-lg mb-10 sm:mb-12"
    >
      Advocacia de excelência para quem não pode arriscar o próprio patrimônio,
      a aposentadoria ou os direitos trabalhistas. Agimos com precisão técnica
      para proteger o que você levou a vida inteira para construir.
    </p>

    <!-- CTAs -->
    <div
      class="hero-reveal-item flex flex-col sm:flex-row items-center sm:items-start justify-center sm:justify-start gap-4 sm:gap-6 w-full sm:w-auto mt-2"
    >
      <a
        href="#contato"
        class="w-full sm:w-auto group relative inline-flex items-center justify-center gap-2 sm:gap-3 px-6 sm:px-10 py-4 sm:py-4 bg-gradient-to-r from-[#D4AF37] via-[#F3E5AB] to-[#D4AF37] text-dark font-semibold tracking-widest uppercase text-xs sm:text-[11px] rounded-full overflow-hidden transition-all shadow-[0_4px_20px_rgba(212,175,55,0.2)] hover:shadow-[0_4px_30px_rgba(212,175,55,0.4)] hover:scale-[1.02]"
      >
        <div
          class="absolute inset-0 bg-gradient-to-r from-[#F3E5AB] via-[#D4AF37] to-[#F3E5AB] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        >
        </div>
        <span class="relative z-10">Falar com um especialista</span>
        <ArrowRight
          class="w-4 h-4 sm:w-4 sm:h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-1"
        />
      </a>

      <a
        href="#sobre"
        class="w-full sm:w-auto group relative inline-flex items-center justify-center sm:justify-start gap-3 sm:gap-4 px-4 sm:px-4 py-2 text-white font-medium transition-all"
      >
        <div
          class="relative flex items-center justify-center w-12 h-12 rounded-full border border-white/20 bg-white/5 backdrop-blur-md transition-all duration-300 group-hover:border-gold group-hover:bg-gold/10 group-hover:scale-105"
        >
          <Play
            class="w-4 h-4 text-white group-hover:text-gold-light ml-1 transition-colors"
          />
        </div>
        <span
          class="text-xs uppercase tracking-widest text-gray-300 group-hover:text-white transition-colors"
          >Como Trabalhamos</span
        >
      </a>
    </div>
  </div>

  <!-- Scroll Indicator — anchored at bottom of viewport, bounce animation -->
  <div
    class="relative z-10 flex flex-col items-center hero-reveal-item scroll-invite"
    style="padding-bottom: clamp(0.75rem, 2vh, 1.5rem); gap: clamp(0.25rem, 0.5vh, 0.5rem);"
  >
    <span
      class="text-[8px] sm:text-[9px] font-semibold uppercase tracking-[0.3em] text-white/70"
      >Descubra</span
    >
    <div
      class="w-px bg-gradient-to-b from-gold to-transparent"
      style="height: clamp(1.25rem, 3.5vh, 3rem);"
    >
    </div>
  </div>
</section>

<style>
  .scroll-invite {
    animation: scrollBounce 2s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes scrollBounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    // 1. Image slow scale effect
    gsap.fromTo(
      ".hero-image-scale",
      { scale: 1.1, filter: "blur(5px)" },
      { scale: 1, filter: "blur(0px)", duration: 2.5, ease: "power2.out" },
    );

    // 2. Title word reveal
    gsap.fromTo(
      ".hero-title span",
      { y: 50, opacity: 0, rotationX: -15 },
      {
        y: 0,
        opacity: 1,
        rotationX: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power3.out",
        delay: 0.2,
      },
    );

    // 3. Other items reveal
    gsap.fromTo(
      ".hero-reveal-item",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out",
        delay: 0.6,
      },
    );
  });
</script>
